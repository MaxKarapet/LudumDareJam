<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <RollForward>LatestMajor</RollForward>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>IsaacDungeonLayout</RootNamespace>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>
  <!-- Godot-скрипты собираются вместе с игрой (Godot.NET.Sdk); в консольной сборке библиотеки Godot нет. -->
  <ItemGroup>
    <Compile Remove="LevelGenerator.cs" />
    <Compile Remove="RoomScene.cs" />
  </ItemGroup>
</Project>
